---
// Demo.astro
---
<section class="demo section section-alt">
  <div class="container text-center">
    <h2>See it in action.</h2>
    
    <div class="video-container">
      <iframe 
        width="100%" 
        height="100%" 
        src="https://www.youtube.com/embed/aoLFoSFGTVI" 
        title="Dyslexia Reader Demo Video" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen
        class="demo-video"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .demo {
    padding: var(--spacing-16) 0;
  }
  h2 {
    margin-bottom: var(--spacing-8);
  }
  .video-container {
    max-width: 800px;
    margin: 0 auto;
    aspect-ratio: 16/9;
    background-color: var(--color-bg-surface);
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .demo-video {
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
