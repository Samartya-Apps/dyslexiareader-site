---
// Footer.astro
const currentYear = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col brand-col">
      <div class="logo">
        <img src="/img/dyslexia-reader-icon.png" alt="Dyslexia Reader Logo" width="32" height="32" />
        <span class="logo-text">Dyslexia Reader</span>
      </div>
      <p class="brand-desc">A product of Samartya Apps.</p>
      
      <div class="social-links">
        <a href="#" aria-label="Facebook">FB</a>
        <a href="#" aria-label="Instagram">IG</a>
        <a href="#" aria-label="LinkedIn">LI</a>
        <a href="#" aria-label="YouTube">YT</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Products</h4>
      <ul>
        <li><a href="https://freespeechapp.com">FreeSpeech</a></li>
        <li><a href="/">Dyslexia Reader</a></li>
        <li><a href="https://samartya.com/for-schools">For Schools</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <ul>
        <li><a href="https://samartya.com/about">About Samartya Apps</a></li>
        <li><a href="https://samartya.com/research">Research & Evidence</a></li>
        <li><a href="https://samartya.com/blog">Blog</a></li>
        <li><a href="https://samartya.com/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Legal</h4>
      <ul>
        <li><a href="https://samartya.com/privacy">Privacy Policy</a></li>
        <li><a href="https://samartya.com/terms">Terms of Use</a></li>
      </ul>
      
      <h4 style="margin-top: 1.5rem;">Download</h4>
      <div class="app-badges">
        <a href="https://apps.apple.com/us/app/dyslexia-reader-by-mda/id1443891619" class="badge" target="_blank" rel="noopener noreferrer">App Store</a>
        <a href="https://play.google.com/store/apps/details?id=com.avaz.readerapp" class="badge" target="_blank" rel="noopener noreferrer">Google Play</a>
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {currentYear} Samartya Apps. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-alt);
    padding: var(--spacing-16) 0 var(--spacing-8);
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-12);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-2);
  }

  .logo-text {
    font-family: var(--font-family-heading);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text-main);
  }

  .brand-desc {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-6);
  }

  .footer-col h4 {
    font-size: 1rem;
    margin-bottom: var(--spacing-4);
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .footer-col a {
    color: var(--color-text-muted);
  }

  .footer-col a:hover {
    color: var(--color-primary);
  }

  .social-links {
    display: flex;
    gap: var(--spacing-4);
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-main);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .social-links a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .app-badges {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .badge {
    display: inline-block;
    padding: var(--spacing-2) var(--spacing-4);
    background-color: var(--color-text-main);
    color: var(--color-bg-surface);
    border-radius: var(--border-radius-md);
    text-align: center;
    font-weight: 500;
  }
  
  .badge:hover {
    background-color: var(--color-primary);
    color: var(--color-bg-surface);
    text-decoration: none;
  }

  .footer-bottom {
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .brand-col {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
